---
layout: base.njk
---
<article class="post-page">
  <a class="back-link" href="/#writing">← All writing</a>
  <time class="mono" datetime="{{ page.date | isoDateShort }}">{{ page.date | readableDate }}</time>
  <h1 class="post-heading">{{ title }}</h1>
  <div class="post-body">
    {{ content | safe }}
  </div>
</article>
